{
  "name": "@ghentcdh/json-forms-vue",
  "version": "1.1.1",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./testing": {
      "types": "./testing/index.d.ts",
      "import": "./testing.mjs",
      "require": "./testing.js"
    },
    "./index.css": "./index.css"
  },
  "files": [
    "*.js",
    "*.cjs",
    "**/*.d.ts",
    "*.css",
    "testing/**"
  ],
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "dependencies": {
    "@jsonforms/core": "^3.4.0",
    "vee-validate": ">=4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.50.0",
    "@ghentcdh/json-forms-core": ">=0.0.1",
    "@ghentcdh/ui": ">=0.6.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "vue": "3.5.29",
    "vue-router": "5.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GhentCDH/ghentcdh-monorepo.git"
  }
}
