    "*.cjs",
    "*.mjs",
    "*.d.ts",
    "*.css",
    "*.md",
    "assets/**",
    "alert/**",
    "button/**",
    "card/**",
    "collapse/**",
    "composables/**",
    "const/**",
    "directives/**",
    "drawer/**",
    "filter/**",
    "form/**",
    "icons/**",
    "loading/**",
    "menu/**",
    "modal/**",
    "shell/**",
    "table/**",
    "test-utils/**",
    "testing/**",
    "toast/**",
    "tree/**",
    "utils/**"
  ],
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/vue-3": {
      "optional": true
    },
    "tiptap-markdown": {
