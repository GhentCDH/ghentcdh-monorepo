    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/vue-3": "^3.0.0",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@tiptap/vue-3": "3.27.1",
    "daisyui": "5.5.23",
    "tailwindcss": "4.3.1",
    "tiptap-markdown": "0.9.0",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
